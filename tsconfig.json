{
  "compilerOptions":{
    "target": "ES6",
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "outDir": "./dist",
      "moduleResolution": "node",
  },
  "include": ["src/**/*"]
}

